// Prisma Schema - GPT Image Studio
// 数据库：PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户表
// ============================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  creditsBalance Int      @default(50) // 剩余额度（张数）
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth 关联
  accounts Account[]
  sessions Session[]

  // 业务关联
  generations     Generation[]
  referenceImages ReferenceImage[]
  creditLogs      CreditLog[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ============================================
// NextAuth 必需表
// ============================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// 生图任务表
// ============================================
model Generation {
  id        String           @id @default(cuid())
  userId    String
  prompt    String           @db.Text
  model     String           @default("gpt-image-1") // gpt-image-1
  quality   ImageQuality     @default(MEDIUM)
  size      ImageSize        @default(S_1024x1024)
  n         Int              @default(1) // 一次生成几张
  format    ImageFormat      @default(PNG)
  background ImageBackground @default(AUTO)
  status    GenerationStatus @default(PENDING)
  error     String?          @db.Text
  costCredits Int            @default(0) // 本次消耗额度
  costUsd     Float          @default(0) // 本次消耗美元
  createdAt DateTime         @default(now())
  completedAt DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  images Image[]

  // 参考图关联（多张，最多 5 张）
  referenceImages ReferenceImage[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("generations")
}

enum GenerationStatus {
  PENDING    // 排队中
  PROCESSING // 生成中
  COMPLETED  // 完成
  FAILED     // 失败
}

enum ImageQuality {
  LOW
  MEDIUM
  HIGH
  AUTO
}

enum ImageSize {
  S_1024x1024
  S_1024x1536
  S_1536x1024
  S_AUTO
}

enum ImageFormat {
  PNG
  JPEG
  WEBP
}

enum ImageBackground {
  AUTO
  TRANSPARENT
  OPAQUE
}

// ============================================
// 生成的图片表
// ============================================
model Image {
  id           String   @id @default(cuid())
  generationId String
  storageKey   String   // R2 对象存储 key
  url          String   // 公开访问 URL
  format       String   @default("png")
  width        Int?
  height       Int?
  fileSize     Int?     // 字节数
  createdAt    DateTime @default(now())

  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@map("images")
}

// ============================================
// 参考图（用于编辑模式）
// ============================================
model ReferenceImage {
  id         String   @id @default(cuid())
  userId     String
  storageKey String   // R2 对象存储 key
  url        String
  filename   String?
  fileSize   Int?
  createdAt  DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([userId])
  @@map("reference_images")
}

// ============================================
// 额度变动日志
// ============================================
model CreditLog {
  id           String       @id @default(cuid())
  userId       String
  delta        Int          // 正数=充值/赠送，负数=消耗
  balanceAfter Int          // 变动后余额
  reason       CreditReason
  description  String?
  generationId String?      // 关联的生图任务（如果是消耗）
  createdAt    DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("credit_logs")
}

enum CreditReason {
  INITIAL_GRANT  // 注册赠送
  ADMIN_GRANT    // 管理员充值
  GENERATION     // 生图消耗
  REFUND         // 失败退款
}
